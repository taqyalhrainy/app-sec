# Security: Environment Variables Configuration
# Copy this file to .env and fill in the values

# Port for backend server
PORT=5000

# JWT Secret Key (Change to a strong random value)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Encryption Key for sensitive fields (32 bytes for AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-encryption-key-32-bytes-hex-change-this

# CORS Origin (Frontend URL)
CORS_ORIGIN=http://localhost:3000

# Node Environment
NODE_ENV=development
